<%= form_with model: [:admin, organization], class: "space-y-5" do |f| %>

  <% if organization.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg px-4 py-3 text-sm text-red-700">
      <ul class="list-disc list-inside space-y-1">
        <% organization.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "Nombre de la organización", class: "block text-sm font-medium text-zinc-700 mb-1" %>
    <%= f.text_field :name, placeholder: "Ej. Abarrotes García",
          class: "w-full border border-zinc-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
  </div>

  <div>
    <%= f.label :subdomain, "Subdominio", class: "block text-sm font-medium text-zinc-700 mb-1" %>
    <div class="flex items-center gap-0">
      <%= f.text_field :subdomain, placeholder: "abarrotes-garcia",
            class: "w-full border border-zinc-300 rounded-l-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
      <span class="bg-zinc-100 border border-l-0 border-zinc-300 rounded-r-lg px-3 py-2 text-sm text-zinc-500 whitespace-nowrap">.paynow.mx</span>
    </div>
    <p class="text-xs text-zinc-400 mt-1">Solo letras minúsculas, números y guiones.</p>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit class: "bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-5 py-2 rounded-lg transition-colors cursor-pointer" %>
    <%= link_to "Cancelar", admin_organizations_path, class: "text-sm text-zinc-500 hover:text-zinc-700" %>
  </div>

<% end %>
