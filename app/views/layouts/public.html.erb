<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= content_for?(:title) ? yield(:title) + " · PayNow" : "PayNow" %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
      body { font-family: 'Inter', 'Helvetica Neue', Helvetica, Arial, sans-serif; }
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(10px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .animate-up { animation: fadeUp 0.3s ease both; }
    </style>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  </head>

  <body class="bg-[#060a14] text-slate-100 antialiased min-h-dvh">

    <%# ── Flash ──────────────────────────────────────── %>
    <% if notice.present? %>
      <div class="fixed top-4 left-1/2 -translate-x-1/2 z-50 animate-up
                  bg-green-950 border border-green-700 text-green-300
                  rounded-2xl px-5 py-3 text-sm font-medium shadow-xl
                  flex items-center gap-2 whitespace-nowrap">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
        </svg>
        <%= notice %>
      </div>
    <% end %>

    <%# ── Contenido ───────────────────────────────────── %>
    <main>
      <%= yield %>
    </main>

    <%# ── Footer ─────────────────────────────────────── %>
    <footer class="py-8 text-center">
      <a href="/" class="inline-flex items-center gap-1.5 no-underline opacity-40 hover:opacity-70 transition-opacity">
        <svg width="16" height="16" viewBox="0 0 38 38" fill="none">
          <rect width="38" height="38" rx="10" fill="#6366f1"/>
          <path d="M22 8l-8 13h6l-2 9 12-15h-7l3-7z" fill="white"/>
        </svg>
        <span class="text-xs font-bold tracking-tight text-slate-400">PayNow</span>
      </a>
    </footer>

  </body>
</html>
