<% content_for :title, @organization.name %>

<div class="space-y-8">

  <%# ── Header ─────────────────────────────────────── %>
  <div class="flex items-start justify-between gap-4">
    <div>
      <%= link_to "← Organizaciones", admin_organizations_path,
            class: "text-sm text-slate-500 hover:text-slate-300 transition-colors" %>
      <h1 class="text-2xl font-bold tracking-tight mt-2"><%= @organization.name %></h1>
      <p class="text-sm font-mono text-slate-500 mt-0.5"><%= @organization.subdomain %>.paynow.mx</p>
    </div>
    <%= link_to "Editar", edit_admin_organization_path(@organization),
          class: "text-sm font-medium text-slate-400 border border-[#1e2d45] rounded-xl px-4 py-2
                  hover:border-slate-500 hover:text-slate-200 transition-colors shrink-0" %>
  </div>

  <%# ── Usuarios ────────────────────────────────────── %>
  <section>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-base font-semibold text-slate-100">Usuarios</h2>
      <%= link_to "Nuevo usuario", new_admin_organization_user_path(@organization),
            class: "inline-flex items-center bg-[#6366f1] hover:bg-[#818cf8] text-white
                    text-sm font-semibold px-4 py-2.5 rounded-xl transition-colors" %>
    </div>

    <% if @users.any? %>
      <div class="bg-[#0f172a] border border-[#1e2d45] rounded-xl divide-y divide-[#1e2d45]">
        <% @users.each do |user| %>
          <div class="flex items-center justify-between px-5 py-4">
            <div>
              <p class="text-sm font-medium text-slate-100"><%= user.email_address %></p>
              <p class="text-xs text-slate-500 mt-0.5">
                <%= user.businesses.count %> negocios · Business Owner
              </p>
            </div>
            <div class="flex items-center gap-4">
              <%= link_to "Editar", edit_admin_user_path(user),
                    class: "text-sm text-slate-500 hover:text-slate-300 transition-colors" %>
              <%= link_to "Eliminar", admin_user_path(user),
                    data: { turbo_method: :delete, turbo_confirm: "¿Eliminar a #{user.email_address}?" },
                    class: "text-sm text-red-500 hover:text-red-400 transition-colors" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-[#0f172a] border-2 border-dashed border-[#1e2d45] rounded-xl p-10 text-center">
        <p class="text-slate-500 text-sm">Sin usuarios aún.</p>
        <%= link_to "Crear primer usuario", new_admin_organization_user_path(@organization),
              class: "mt-2 inline-block text-sm font-medium text-[#6366f1] hover:text-[#818cf8]" %>
      </div>
    <% end %>
  </section>

</div>
