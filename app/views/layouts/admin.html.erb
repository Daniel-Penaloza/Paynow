<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= content_for?(:title) ? yield(:title) + " · PayNow Admin" : "PayNow Admin" %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>body { font-family: 'Inter', 'Helvetica Neue', Helvetica, Arial, sans-serif; }</style>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-[#060a14] text-slate-100 antialiased">
    <div class="min-h-screen flex flex-col">

      <%# ── Navbar ─────────────────────────────────────── %>
      <header class="bg-[#0f172a] border-b border-[#1e2d45] sticky top-0 z-10">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-14">

          <div class="flex items-center gap-6">
            <a href="<%= admin_root_path %>" class="inline-flex items-center gap-2 no-underline">
              <svg width="26" height="26" viewBox="0 0 38 38" fill="none">
                <rect width="38" height="38" rx="10" fill="#6366f1"/>
                <path d="M22 8l-8 13h6l-2 9 12-15h-7l3-7z" fill="white"/>
              </svg>
              <span class="font-extrabold tracking-[-0.04em] text-slate-100">
                Pay<em class="not-italic text-[#6366f1]">Now</em>
              </span>
              <span class="text-[10px] font-semibold tracking-widest uppercase text-slate-500 ml-1">Admin</span>
            </a>

            <nav class="hidden sm:flex items-center gap-1">
              <%= link_to "Organizaciones", admin_organizations_path,
                    class: "px-3 py-1.5 rounded-lg text-sm font-medium text-slate-400
                            hover:bg-[#1e2d45] hover:text-slate-100 transition-colors" %>
            </nav>
          </div>

          <div class="flex items-center gap-4">
            <span class="text-sm text-slate-500 hidden sm:block"><%= Current.user.email_address %></span>
            <%= button_to "Salir", session_path, method: :delete,
                  class: "text-sm text-slate-500 hover:text-slate-300 transition-colors cursor-pointer
                          bg-transparent border-none p-0" %>
          </div>
        </div>
      </header>

      <%# ── Flash ──────────────────────────────────────── %>
      <% if notice.present? %>
        <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-5 w-full">
          <div class="bg-green-950 border border-green-800 text-green-400 rounded-xl px-4 py-3 text-sm">
            <%= notice %>
          </div>
        </div>
      <% end %>
      <% if alert.present? %>
        <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-5 w-full">
          <div class="bg-red-950 border border-red-800 text-red-400 rounded-xl px-4 py-3 text-sm">
            <%= alert %>
          </div>
        </div>
      <% end %>

      <%# ── Main ───────────────────────────────────────── %>
      <main class="flex-1 max-w-6xl mx-auto px-4 sm:px-6 py-8 w-full">
        <%= yield %>
      </main>

      <%# ── Footer ─────────────────────────────────────── %>
      <footer class="border-t border-[#1e2d45] py-4 text-center text-xs text-slate-600">
        PayNow Admin &copy; <%= Date.current.year %>
      </footer>

    </div>
  </body>
</html>
