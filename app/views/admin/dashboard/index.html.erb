<% content_for :title, "Dashboard" %>

<div class="space-y-8">

  <div>
    <h1 class="text-2xl font-bold tracking-tight">Panel de control</h1>
    <p class="text-slate-500 mt-1 text-sm">Visión general de la plataforma.</p>
  </div>

  <%# ── Stats ──────────────────────────────────────── %>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <div class="bg-[#0f172a] border border-[#1e2d45] rounded-xl p-5">
      <p class="text-xs font-bold tracking-widest uppercase text-slate-500">Organizaciones</p>
      <p class="text-3xl font-extrabold tracking-tight mt-2 text-slate-100"><%= Organization.count %></p>
    </div>
    <div class="bg-[#0f172a] border border-[#1e2d45] rounded-xl p-5">
      <p class="text-xs font-bold tracking-widest uppercase text-slate-500">Usuarios</p>
      <p class="text-3xl font-extrabold tracking-tight mt-2 text-slate-100"><%= User.business_owner.count %></p>
    </div>
    <div class="bg-[#0f172a] border border-[#1e2d45] rounded-xl p-5">
      <p class="text-xs font-bold tracking-widest uppercase text-slate-500">Comprobantes</p>
      <p class="text-3xl font-extrabold tracking-tight mt-2 text-slate-100"><%= Receipt.count %></p>
    </div>
  </div>

  <%# ── Organizaciones recientes ───────────────────── %>
  <section>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-base font-semibold text-slate-100">Organizaciones recientes</h2>
      <%= link_to "Ver todas →", admin_organizations_path,
            class: "text-sm text-[#6366f1] hover:text-[#818cf8] transition-colors" %>
    </div>

    <% if @organizations.any? %>
      <div class="bg-[#0f172a] border border-[#1e2d45] rounded-xl divide-y divide-[#1e2d45]">
        <% @organizations.each do |org| %>
          <div class="flex items-center justify-between px-5 py-4">
            <div>
              <p class="text-sm font-medium text-slate-100"><%= org.name %></p>
              <p class="text-xs text-slate-500 font-mono mt-0.5">
                <%= org.subdomain %>.paynow.mx · <%= org.users.count %> usuarios
              </p>
            </div>
            <%= link_to "Ver →", admin_organization_path(org),
                  class: "text-sm text-[#6366f1] hover:text-[#818cf8] transition-colors shrink-0" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-[#0f172a] border-2 border-dashed border-[#1e2d45] rounded-xl p-12 text-center">
        <p class="text-slate-500 text-sm">No hay organizaciones aún.</p>
        <%= link_to "Crear primera organización", new_admin_organization_path,
              class: "mt-2 inline-block text-sm font-medium text-[#6366f1] hover:text-[#818cf8]" %>
      </div>
    <% end %>
  </section>

</div>
