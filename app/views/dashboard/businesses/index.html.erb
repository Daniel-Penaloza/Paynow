<% content_for :title, "Negocios" %>

<div class="space-y-6">

  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-bold tracking-tight">Negocios</h1>
      <p class="text-slate-500 text-sm mt-0.5">Todos tus negocios registrados.</p>
    </div>
    <%= link_to "Nuevo negocio", new_dashboard_business_path,
          class: "inline-flex items-center bg-[#6366f1] hover:bg-[#818cf8] text-white
                  text-sm font-semibold px-4 py-2.5 rounded-xl transition-colors shrink-0" %>
  </div>

  <% if @businesses.any? %>
    <div class="bg-[#0f172a] border border-[#1e2d45] rounded-xl divide-y divide-[#1e2d45]">
      <% @businesses.each do |business| %>
        <div class="flex items-center justify-between px-5 py-4 gap-4">
          <div class="min-w-0 flex-1">
            <p class="font-semibold text-slate-100 truncate"><%= business.name %></p>
            <p class="text-sm text-slate-500 mt-0.5">
              <%= business.holder_name %> ·
              <span class="font-mono"><%= business.clabe %></span>
            </p>
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <span class="text-xs text-slate-600 hidden sm:block">
              <%= business.receipts.count %> comprobantes
            </span>
            <%= link_to "Ver", dashboard_business_path(business),
                  class: "text-sm text-slate-400 border border-[#1e2d45] rounded-lg px-3 py-1.5
                          hover:border-slate-500 hover:text-slate-200 transition-colors" %>
            <%= link_to "QR", qr_dashboard_business_path(business),
                  class: "text-sm text-[#6366f1] border border-[#6366f1]/30 rounded-lg px-3 py-1.5
                          hover:bg-[#6366f1]/10 transition-colors" %>
            <%= link_to "Editar", edit_dashboard_business_path(business),
                  class: "text-sm text-slate-400 border border-[#1e2d45] rounded-lg px-3 py-1.5
                          hover:border-slate-500 hover:text-slate-200 transition-colors" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-[#0f172a] border-2 border-dashed border-[#1e2d45] rounded-xl p-16 text-center">
      <p class="text-slate-500 text-sm">No tienes negocios registrados aún.</p>
      <%= link_to "Crea tu primer negocio", new_dashboard_business_path,
            class: "mt-2 inline-block text-sm font-medium text-[#6366f1] hover:text-[#818cf8]" %>
    </div>
  <% end %>

</div>
