<% content_for :title, "Comprobantes · #{@business.name}" %>

<div class="space-y-6">

  <div>
    <%= link_to "← #{@business.name}", dashboard_business_path(@business),
          class: "text-sm text-slate-500 hover:text-slate-300 transition-colors" %>
    <h1 class="text-2xl font-bold tracking-tight mt-2">Comprobantes</h1>
    <p class="text-slate-500 text-sm mt-0.5"><%= @business.name %></p>
  </div>

  <%# Filtros rápidos %>
  <div class="flex flex-wrap gap-2">
    <% quick_filters = [
      ["Todos",       nil,          "all"],
      ["Hoy",         "today",      "today"],
      ["Esta semana", "this_week",  "this_week"],
      ["Este mes",    "this_month", "this_month"],
      ["Este año",    "this_year",  "this_year"]
    ] %>

    <% quick_filters.each do |label, period_value, key| %>
      <% active = (period_value.nil? && @period.blank? && @date_from.blank?) || @period == period_value %>
      <%= link_to label,
            dashboard_business_receipts_path(@business, period: period_value),
            class: [
              "px-4 py-1.5 rounded-full text-sm font-medium transition-colors",
              active ? "bg-[#6366f1] text-white" : "bg-[#0f172a] border border-[#1e2d45] text-slate-400 hover:text-slate-200 hover:border-slate-500"
            ].join(" ") %>
    <% end %>
  </div>

  <%# Filtro por rango de fechas %>
  <%= form_with url: dashboard_business_receipts_path(@business), method: :get,
        class: "flex flex-wrap items-end gap-3" do |f| %>
    <div class="flex flex-col gap-1">
      <label class="text-xs text-slate-500">Desde</label>
      <%= f.date_field :date_from, value: @date_from,
            class: "bg-[#0f172a] border border-[#1e2d45] rounded-lg px-3 py-2 text-sm text-slate-200 focus:outline-none focus:border-[#6366f1]" %>
    </div>
    <div class="flex flex-col gap-1">
      <label class="text-xs text-slate-500">Hasta</label>
      <%= f.date_field :date_to, value: @date_to,
            class: "bg-[#0f172a] border border-[#1e2d45] rounded-lg px-3 py-2 text-sm text-slate-200 focus:outline-none focus:border-[#6366f1]" %>
    </div>
    <%= f.submit "Filtrar",
          class: "px-4 py-2 bg-[#1e2d45] border border-[#1e2d45] rounded-lg text-sm text-slate-200 hover:border-slate-500 cursor-pointer transition-colors" %>
    <% if @date_from.present? || @date_to.present? %>
      <%= link_to "Limpiar", dashboard_business_receipts_path(@business),
            class: "px-4 py-2 text-sm text-slate-500 hover:text-slate-300 transition-colors" %>
    <% end %>
  <% end %>

  <%# Contador de resultados %>
  <p class="text-sm text-slate-500">
    <% if @total_count == 0 %>
      Sin comprobantes
    <% elsif @total_count == 1 %>
      1 comprobante
    <% else %>
      <%= @total_count %> comprobantes
    <% end %>
    <% if @period.present? %>
      · <span class="text-slate-400"><%= { "today" => "hoy", "this_week" => "esta semana", "this_month" => "este mes", "this_year" => "este año" }[@period] %></span>
    <% elsif @date_from.present? || @date_to.present? %>
      · <span class="text-slate-400">rango personalizado</span>
    <% end %>
  </p>

  <% if @receipts.any? %>
    <div class="bg-[#0f172a] border border-[#1e2d45] rounded-xl divide-y divide-[#1e2d45]">
      <% @receipts.each do |receipt| %>
        <div class="flex items-center justify-between px-5 py-4">
          <div>
            <p class="text-sm font-medium text-slate-100">
              <%= receipt.submitted_at.strftime("%d de %B de %Y") %>
            </p>
            <p class="text-xs text-slate-500 mt-0.5">
              <%= receipt.submitted_at.strftime("%H:%M hrs") %>
            </p>
          </div>
          <%= link_to "Ver comprobante →", dashboard_business_receipt_path(@business, receipt),
                class: "text-sm text-[#6366f1] hover:text-[#818cf8] transition-colors" %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-[#0f172a] border-2 border-dashed border-[#1e2d45] rounded-xl p-16 text-center">
      <p class="text-slate-500 text-sm">No hay comprobantes para este período.</p>
    </div>
  <% end %>

</div>
