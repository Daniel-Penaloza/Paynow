<% content_for :title, "Editar usuario — #{@user.email_address}" %>

<div class="max-w-lg space-y-6">
  <div>
    <%= link_to "← #{@organization.name}", admin_organization_path(@organization),
          class: "text-sm text-slate-500 hover:text-slate-300 transition-colors" %>
    <h1 class="text-2xl font-bold tracking-tight mt-2">Editar usuario</h1>
    <p class="text-slate-500 font-mono text-sm mt-0.5"><%= @user.email_address %></p>
  </div>

  <div class="bg-[#0f172a] border border-[#1e2d45] rounded-xl p-6">
    <%= render "form" %>
  </div>

  <div class="border-t border-[#1e2d45] pt-6">
    <h2 class="text-xs font-bold tracking-widest uppercase text-slate-600 mb-3">Zona de peligro</h2>
    <%= link_to "Eliminar usuario", admin_user_path(@user),
          data: { turbo_method: :delete, turbo_confirm: "¿Eliminar a #{@user.email_address}? Esta acción no se puede deshacer." },
          class: "text-sm text-red-500 hover:text-red-400 transition-colors font-medium" %>
  </div>
</div>
