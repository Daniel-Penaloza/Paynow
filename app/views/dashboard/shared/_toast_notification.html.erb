<div class="toast-notification pointer-events-auto
            flex items-start gap-3
            bg-[#0f172a] border border-[#6366f1]/40
            shadow-[0_8px_32px_rgba(0,0,0,0.5)]
            rounded-2xl px-4 py-3 w-72
            animate-[slideIn_0.3s_ease_both]"
     style="animation: slideIn 0.3s ease both;">

  <div class="shrink-0 w-8 h-8 rounded-full bg-[#6366f1]/15 border border-[#6366f1]/30
              flex items-center justify-center mt-0.5">
    <svg class="w-4 h-4 text-[#6366f1]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
        d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
    </svg>
  </div>

  <div class="flex-1 min-w-0">
    <p class="text-sm font-semibold text-slate-100">Nuevo comprobante</p>
    <p class="text-xs text-slate-400 mt-0.5 truncate"><%= receipt.business.name %></p>
    <p class="text-xs text-slate-500 mt-0.5"><%= receipt.submitted_at.strftime("%H:%M hrs") %></p>
  </div>

  <%= link_to "Ver",
        dashboard_business_receipt_path(receipt.business, receipt),
        class: "shrink-0 text-xs font-semibold text-[#6366f1] hover:text-[#818cf8]
                transition-colors self-center" %>
</div>
