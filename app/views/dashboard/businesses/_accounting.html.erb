<section id="accounting_<%= business.id %>">
  <h2 class="text-xs font-bold tracking-widest uppercase text-slate-500 mb-4">Ingresos verificados</h2>
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
    <% receipts = business.receipts %>
    <% [
      { label: "Hoy",         amount: receipts.today.total_amount,      count: receipts.today.verified.count },
      { label: "Esta semana", amount: receipts.this_week.total_amount,  count: receipts.this_week.verified.count },
      { label: "Este mes",    amount: receipts.this_month.total_amount, count: receipts.this_month.verified.count },
      { label: "Este año",    amount: receipts.this_year.total_amount,  count: receipts.this_year.verified.count }
    ].each do |period| %>
      <div class="bg-[#0f172a] border border-[#1e2d45] rounded-xl p-4">
        <p class="text-xs text-slate-500 mb-2"><%= period[:label] %></p>
        <p class="text-lg font-bold text-slate-100 leading-none">
          $<%= number_with_delimiter(period[:amount], precision: 2, separator: ".", delimiter: ",") %>
        </p>
        <p class="text-xs text-slate-600 mt-1.5">
          <%= period[:count] %> <%= period[:count] == 1 ? "pago" : "pagos" %>
        </p>
      </div>
    <% end %>
  </div>
</section>
