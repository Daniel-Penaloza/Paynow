<div class="flex items-center justify-between px-5 py-4
            animate-[fadeIn_0.3s_ease_both]"
     style="animation: fadeIn 0.3s ease both;">
  <div>
    <p class="text-sm font-medium text-slate-100">
      <%= receipt.submitted_at.strftime("%d de %B de %Y") %>
    </p>
    <p class="text-xs text-slate-500 mt-0.5">
      <%= receipt.submitted_at.strftime("%H:%M hrs") %>
    </p>
  </div>
  <%= link_to "Ver →", dashboard_business_receipt_path(business, receipt),
        class: "text-sm text-[#6366f1] hover:text-[#818cf8] transition-colors" %>
</div>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
