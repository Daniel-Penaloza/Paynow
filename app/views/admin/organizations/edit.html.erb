<% content_for :title, "Editar organización" %>

<div class="max-w-xl space-y-6">
  <div>
    <%= link_to "← #{@organization.name}", admin_organization_path(@organization),
          class: "text-sm text-slate-500 hover:text-slate-300 transition-colors" %>
    <h1 class="text-2xl font-bold tracking-tight mt-2">Editar organización</h1>
    <p class="text-slate-500 text-sm mt-0.5"><%= @organization.name %></p>
  </div>

  <div class="bg-[#0f172a] border border-[#1e2d45] rounded-xl p-6">
    <%= render "form", organization: @organization %>
  </div>

  <div class="border-t border-[#1e2d45] pt-6">
    <h2 class="text-xs font-bold tracking-widest uppercase text-slate-600 mb-3">Zona de peligro</h2>
    <%= button_to "Eliminar organización", admin_organization_path(@organization), method: :delete,
          data: { turbo_confirm: "¿Seguro? Esto eliminará todos los usuarios y datos de #{@organization.name}." },
          class: "text-sm text-red-500 hover:text-red-400 transition-colors cursor-pointer
                  bg-transparent border-none p-0" %>
  </div>
</div>
