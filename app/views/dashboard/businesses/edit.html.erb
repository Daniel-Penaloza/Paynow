<% content_for :title, "Editar negocio" %>

<div class="max-w-xl space-y-6">
  <div>
    <h1 class="text-2xl font-bold">Editar negocio</h1>
    <p class="text-zinc-500 mt-1"><%= @business.name %></p>
  </div>

  <div class="bg-white border border-zinc-200 rounded-xl p-6">
    <%= render "form", business: @business %>
  </div>

  <div class="border-t border-zinc-200 pt-4">
    <%= button_to "Eliminar negocio", dashboard_business_path(@business), method: :delete,
          data: { turbo_confirm: "¿Seguro que deseas eliminar #{@business.name}? Esta acción no se puede deshacer." },
          class: "text-sm text-red-500 hover:text-red-700 cursor-pointer" %>
  </div>
</div>
