<% content_for :head do %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', 'Helvetica Neue', Helvetica, Arial, sans-serif; }

    .auth-tab--active::after {
      content: '';
      position: absolute;
      bottom: -1px; left: 0; right: 0;
      height: 2px;
      border-radius: 2px 2px 0 0;
      background: #6366f1;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .animate-up { animation: fadeUp 0.22s ease both; }
  </style>
<% end %>

<div class="min-h-dvh flex items-center justify-center bg-[#060a14] md:py-8 md:px-4">

  <div class="w-full max-w-[430px] min-h-dvh md:min-h-0 bg-[#0f172a] flex flex-col
              md:rounded-[26px] md:overflow-hidden
              md:shadow-[0_32px_80px_rgba(0,0,0,0.6),0_0_0_1px_rgba(255,255,255,0.04)]">

    <%# ── Header ─────────────────────────────────────── %>
    <header class="pt-[52px] px-6">

      <a href="/" class="inline-flex items-center gap-[10px] no-underline">
        <svg width="38" height="38" viewBox="0 0 38 38" fill="none">
          <rect width="38" height="38" rx="10" fill="#6366f1"/>
          <path d="M22 8l-8 13h6l-2 9 12-15h-7l3-7z" fill="white"/>
        </svg>
        <span class="text-[21px] font-extrabold tracking-[-0.04em] text-slate-100">
          Pay<em class="not-italic text-[#6366f1]">Now</em>
        </span>
      </a>

      <p class="mt-[6px] text-[11px] font-medium tracking-[0.1em] uppercase text-slate-500">
        Cobros sin efectivo · QR instantáneo
      </p>

      <div class="mt-9">
        <h1 class="font-extrabold tracking-[-0.035em] leading-[1.12] text-slate-100"
            style="font-size: clamp(26px, 7vw, 32px); text-wrap: pretty;">
          Bienvenido de vuelta
        </h1>
        <p class="mt-2 text-sm text-slate-400 leading-[1.55]">
          Entra a tu panel de cobros con QR
        </p>
      </div>
    </header>

    <%# ── Tabs ───────────────────────────────────────── %>
    <div class="flex mx-6 mt-7 border-b border-[#1e2d45]">
      <button class="auth-tab--active flex-1 py-[10px] border-none bg-transparent cursor-pointer
                     text-[13px] font-semibold text-slate-100 relative transition-colors">
        Iniciar sesión
      </button>
    </div>

    <%# ── Body ───────────────────────────────────────── %>
    <div class="px-6 pt-7 pb-10 flex-1 flex flex-col">

      <% if alert = flash[:alert] %>
        <div class="animate-up mb-4 px-4 py-3 rounded-xl bg-red-950 border border-red-800
                    text-red-400 text-sm leading-snug">
          ⚠ <%= alert %>
        </div>
      <% end %>

      <%= form_with url: session_url, class: "flex flex-col gap-4 flex-1" do |f| %>

        <%# Email %>
        <div class="animate-up flex flex-col gap-[5px]">
          <%= f.label :email_address, "Correo electrónico",
              class: "text-[11px] font-bold tracking-[0.06em] uppercase text-slate-400" %>
          <%= f.email_field :email_address,
              required: true,
              autofocus: true,
              autocomplete: "email",
              placeholder: "hola@negocio.com",
              value: params[:email_address],
              class: "w-full px-[14px] py-[13px] bg-[#080c18] border border-[#1e2d45]
                      rounded-xl text-slate-100 text-[15px] outline-none
                      placeholder:text-[#2d3c55] transition-[border-color,box-shadow]
                      focus:border-[#6366f1] focus:shadow-[0_0_0_3px_rgba(99,102,241,0.18)]
                      [-webkit-appearance:none]" %>
        </div>

        <%# Password %>
        <div class="animate-up flex flex-col gap-[5px]">
          <%= f.label :password, "Contraseña",
              class: "text-[11px] font-bold tracking-[0.06em] uppercase text-slate-400" %>
          <%= f.password_field :password,
              required: true,
              autocomplete: "current-password",
              placeholder: "••••••••",
              maxlength: 72,
              class: "w-full px-[14px] py-[13px] bg-[#080c18] border border-[#1e2d45]
                      rounded-xl text-slate-100 text-[15px] outline-none
                      placeholder:text-[#2d3c55] transition-[border-color,box-shadow]
                      focus:border-[#6366f1] focus:shadow-[0_0_0_3px_rgba(99,102,241,0.18)]
                      [-webkit-appearance:none]" %>
          <%= link_to "¿Olvidaste tu contraseña?", new_password_path,
              class: "self-end text-xs font-medium text-[#6366f1] hover:text-[#818cf8]
                      transition-colors mt-[-4px]" %>
        </div>

        <%# Submit %>
        <div class="flex flex-col gap-[10px] mt-1">
          <%= f.submit "Iniciar sesión",
              data: { "turbo-submits-with": "Iniciando sesión…" },
              class: "w-full py-[15px] px-5 bg-[#6366f1] hover:bg-[#818cf8] text-white
                      rounded-xl text-[15px] font-bold tracking-[-0.01em] cursor-pointer
                      transition-all hover:-translate-y-px
                      hover:shadow-[0_8px_24px_rgba(99,102,241,0.38)]
                      active:translate-y-0 active:shadow-none
                      disabled:opacity-60 disabled:cursor-not-allowed
                      border-none [-webkit-appearance:none]" %>
        </div>

        <p class="mt-5 text-center text-[13px] text-slate-500">
          ¿Eres nuevo en PayNow?
          <span class="text-[#6366f1] font-semibold">Contacta al administrador</span>
        </p>

      <% end %>
    </div>
  </div>
</div>
