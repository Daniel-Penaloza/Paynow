<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= content_for?(:title) ? yield(:title) + " · PayNow" : "PayNow" %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
      body { font-family: 'Inter', 'Helvetica Neue', Helvetica, Arial, sans-serif; }
      @keyframes slideIn {
        from { opacity: 0; transform: translateX(20px); }
        to   { opacity: 1; transform: translateX(0); }
      }
      .toast-notification { animation: slideIn 0.3s ease both; }
    </style>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-[#060a14] text-slate-100 antialiased">
    <div class="min-h-screen flex flex-col">

      <%# ── Navbar ─────────────────────────────────────── %>
      <header class="bg-[#0f172a] border-b border-[#1e2d45] sticky top-0 z-10">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-14">

          <div class="flex items-center gap-6">
            <a href="<%= dashboard_root_path %>" class="inline-flex items-center gap-2 no-underline">
              <svg width="26" height="26" viewBox="0 0 38 38" fill="none">
                <rect width="38" height="38" rx="10" fill="#6366f1"/>
                <path d="M22 8l-8 13h6l-2 9 12-15h-7l3-7z" fill="white"/>
              </svg>
              <span class="font-extrabold tracking-[-0.04em] text-slate-100">
                Pay<em class="not-italic text-[#6366f1]">Now</em>
              </span>
            </a>

            <nav class="hidden sm:flex items-center gap-1">
              <%= link_to "Inicio", dashboard_root_path,
                    class: "px-3 py-1.5 rounded-lg text-sm font-medium transition-colors
                            #{current_page?(dashboard_root_path) ?
                              'bg-[#1e2d45] text-slate-100' :
                              'text-slate-400 hover:bg-[#1e2d45] hover:text-slate-100'}" %>
              <%= link_to "Negocios", dashboard_businesses_path,
                    class: "px-3 py-1.5 rounded-lg text-sm font-medium transition-colors
                            #{request.path.start_with?('/dashboard/businesses') ?
                              'bg-[#1e2d45] text-slate-100' :
                              'text-slate-400 hover:bg-[#1e2d45] hover:text-slate-100'}" %>
              <%# MONETIZATION DISABLED — descomentar para mostrar enlace de suscripción %>
              <%# <%= link_to "Suscripción", dashboard_subscription_path,
                    class: "px-3 py-1.5 rounded-lg text-sm font-medium transition-colors
                            #{request.path.start_with?('/dashboard/subscription') ?
                              'bg-[#1e2d45] text-slate-100' :
                              'text-slate-400 hover:bg-[#1e2d45] hover:text-slate-100'}" %> %>
            </nav>
          </div>

          <div class="flex items-center gap-4">
            <span class="text-sm text-slate-500 hidden sm:block"><%= Current.user.email_address %></span>
            <%= button_to "Salir", session_path, method: :delete,
                  class: "text-sm text-slate-500 hover:text-slate-300 transition-colors cursor-pointer
                          bg-transparent border-none p-0" %>
          </div>
        </div>
      </header>

      <%# ── Flash ──────────────────────────────────────── %>
      <% if notice.present? %>
        <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-5 w-full">
          <div class="bg-green-950 border border-green-800 text-green-400 rounded-xl px-4 py-3 text-sm flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
            </svg>
            <%= notice %>
          </div>
        </div>
      <% end %>
      <% if alert.present? %>
        <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-5 w-full">
          <div class="bg-red-950 border border-red-800 text-red-400 rounded-xl px-4 py-3 text-sm">
            <%= alert %>
          </div>
        </div>
      <% end %>

      <%# MONETIZATION DISABLED — descomentar para mostrar banner de trial %>
      <%# <% org = Current.user.organization %>
      <%# <% if org.on_trial? %>
      <%#   <% days_left = (org.trial_ends_at - Date.current).to_i %>
      <%#   <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-5 w-full">
      <%#     <div class="bg-amber-950 border border-amber-700 text-amber-300 rounded-xl px-4 py-3
      <%#                 text-sm flex items-center justify-between gap-4">
      <%#       ... banner content ...
      <%#     </div>
      <%#   </div>
      <%# <% end %>

      <%# ── Notificaciones en tiempo real ─────────────── %>
    <%= turbo_stream_from "user_#{Current.user.id}_notifications" %>
    <div id="toast_notifications"
         class="fixed top-4 right-4 z-50 flex flex-col gap-2 pointer-events-none">
    </div>

    <%# ── Main ───────────────────────────────────────── %>
      <main class="flex-1 max-w-6xl mx-auto px-4 sm:px-6 py-8 w-full">
        <%= yield %>
      </main>

      <%# ── Footer ─────────────────────────────────────── %>
      <footer class="border-t border-[#1e2d45] py-4 text-center text-xs text-slate-600">
        PayNow &copy; <%= Date.current.year %>
      </footer>

    </div>

    <script>
      (function () {
        function dismissToast(toast) {
          setTimeout(function () {
            toast.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
            toast.style.opacity = '0';
            toast.style.transform = 'translateX(20px)';
            setTimeout(function () { toast.remove(); }, 400);
          }, 5000);
        }

        var container = document.getElementById('toast_notifications');
        if (container) {
          new MutationObserver(function (mutations) {
            mutations.forEach(function (mutation) {
              mutation.addedNodes.forEach(function (node) {
                if (node.nodeType === 1 && node.classList.contains('toast-notification')) {
                  dismissToast(node);
                }
              });
            });
          }).observe(container, { childList: true });
        }
      })();
    </script>

  </body>
</html>
