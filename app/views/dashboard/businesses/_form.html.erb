<%= form_with model: [:dashboard, business], class: "space-y-5" do |f| %>

  <% if business.errors.any? %>
    <div class="bg-red-950 border border-red-800 rounded-xl px-5 py-4">
      <p class="text-sm font-semibold text-red-400 mb-2">
        <%= pluralize(business.errors.count, "error") %> al guardar:
      </p>
      <ul class="list-disc list-inside space-y-1">
        <% business.errors.full_messages.each do |msg| %>
          <li class="text-sm text-red-400"><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Nombre %>
  <div class="flex flex-col gap-[5px]">
    <%= f.label :name, "Nombre del negocio",
        class: "text-[11px] font-bold tracking-[0.06em] uppercase text-slate-400" %>
    <%= f.text_field :name, placeholder: "Ej. Abarrotes La Esperanza",
        class: "w-full px-[14px] py-[13px] bg-[#080c18] border border-[#1e2d45]
                rounded-xl text-slate-100 text-[15px] outline-none
                placeholder:text-[#2d3c55] transition-[border-color,box-shadow]
                focus:border-[#6366f1] focus:shadow-[0_0_0_3px_rgba(99,102,241,0.18)]" %>
  </div>

  <%# CLABE %>
  <div class="flex flex-col gap-[5px]">
    <%= f.label :clabe, "CLABE interbancaria (18 dígitos)",
        class: "text-[11px] font-bold tracking-[0.06em] uppercase text-slate-400" %>
    <%= f.text_field :clabe, placeholder: "000000000000000000", maxlength: 18,
        class: "w-full px-[14px] py-[13px] bg-[#080c18] border border-[#1e2d45]
                rounded-xl text-slate-100 text-[15px] font-mono outline-none
                placeholder:text-[#2d3c55] transition-[border-color,box-shadow]
                focus:border-[#6366f1] focus:shadow-[0_0_0_3px_rgba(99,102,241,0.18)]" %>
  </div>

  <%# Titular %>
  <div class="flex flex-col gap-[5px]">
    <%= f.label :holder_name, "Nombre del titular",
        class: "text-[11px] font-bold tracking-[0.06em] uppercase text-slate-400" %>
    <%= f.text_field :holder_name, placeholder: "Ej. María González López",
        class: "w-full px-[14px] py-[13px] bg-[#080c18] border border-[#1e2d45]
                rounded-xl text-slate-100 text-[15px] outline-none
                placeholder:text-[#2d3c55] transition-[border-color,box-shadow]
                focus:border-[#6366f1] focus:shadow-[0_0_0_3px_rgba(99,102,241,0.18)]" %>
  </div>

  <%# WhatsApp %>
  <div class="flex flex-col gap-[5px]">
    <%= f.label :whatsapp, "WhatsApp (opcional)",
        class: "text-[11px] font-bold tracking-[0.06em] uppercase text-slate-400" %>
    <%= f.text_field :whatsapp, placeholder: "5512345678",
        class: "w-full px-[14px] py-[13px] bg-[#080c18] border border-[#1e2d45]
                rounded-xl text-slate-100 text-[15px] outline-none
                placeholder:text-[#2d3c55] transition-[border-color,box-shadow]
                focus:border-[#6366f1] focus:shadow-[0_0_0_3px_rgba(99,102,241,0.18)]" %>
    <p class="text-xs text-slate-600">Solo números, sin +52</p>
  </div>

  <%# Instrucciones %>
  <div class="flex flex-col gap-[5px]">
    <%= f.label :instructions, "Instrucciones adicionales (opcional)",
        class: "text-[11px] font-bold tracking-[0.06em] uppercase text-slate-400" %>
    <%= f.text_area :instructions, rows: 3,
        placeholder: "Ej. Indica tu nombre en el concepto de la transferencia",
        class: "w-full px-[14px] py-[13px] bg-[#080c18] border border-[#1e2d45]
                rounded-xl text-slate-100 text-[15px] outline-none resize-none
                placeholder:text-[#2d3c55] transition-[border-color,box-shadow]
                focus:border-[#6366f1] focus:shadow-[0_0_0_3px_rgba(99,102,241,0.18)]" %>
  </div>

  <%# Acciones %>
  <div class="flex items-center gap-3 pt-2">
    <%= f.submit class: "bg-[#6366f1] hover:bg-[#818cf8] text-white text-sm font-semibold
                         px-5 py-2.5 rounded-xl transition-colors cursor-pointer border-none" %>
    <%= link_to "Cancelar", dashboard_businesses_path,
        class: "text-sm text-slate-500 hover:text-slate-300 transition-colors" %>
  </div>

<% end %>
