<% content_for :title, "Organizaciones" %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold">Organizaciones</h1>
    <%= link_to "Nueva organización", new_admin_organization_path,
          class: "inline-flex items-center bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors" %>
  </div>

  <% if @organizations.any? %>
    <div class="bg-white border border-zinc-200 rounded-xl divide-y divide-zinc-100">
      <% @organizations.each do |org| %>
        <div class="flex items-center justify-between px-5 py-4">
          <div>
            <p class="font-medium"><%= org.name %></p>
            <p class="text-sm text-zinc-400 mt-0.5 font-mono"><%= org.subdomain %>.paynow.mx</p>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-xs text-zinc-400"><%= org.users.count %> usuarios</span>
            <%= link_to "Ver", admin_organization_path(org),
                  class: "text-sm text-indigo-600 hover:underline" %>
            <%= link_to "Editar", edit_admin_organization_path(org),
                  class: "text-sm text-zinc-500 hover:text-zinc-700" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-white border-2 border-dashed border-zinc-200 rounded-xl p-16 text-center">
      <p class="text-zinc-400">No hay organizaciones registradas.</p>
      <%= link_to "Crear primera organización", new_admin_organization_path,
            class: "mt-2 inline-block text-sm font-medium text-indigo-600 hover:underline" %>
    </div>
  <% end %>
</div>
