<% content_for :title, "Comprobante" %>

<div class="max-w-lg space-y-6">
  <%= link_to "← Comprobantes", dashboard_business_receipts_path(@business), class: "text-sm text-zinc-400 hover:text-zinc-600" %>

  <div>
    <h1 class="text-2xl font-bold">Comprobante</h1>
    <p class="text-zinc-500 mt-0.5"><%= @receipt.submitted_at.strftime("%d de %B de %Y, %H:%M hrs") %></p>
  </div>

  <div class="bg-white border border-zinc-200 rounded-xl overflow-hidden">
    <% if @receipt.file.attached? %>
      <% if @receipt.file.content_type.start_with?("image/") %>
        <%= image_tag url_for(@receipt.file), class: "w-full object-contain max-h-[70vh]" %>
      <% else %>
        <div class="p-8 text-center">
          <svg class="w-12 h-12 mx-auto text-zinc-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
          <%= link_to "Descargar comprobante (PDF)", url_for(@receipt.file),
                class: "text-sm text-indigo-600 hover:underline", target: "_blank" %>
        </div>
      <% end %>
    <% else %>
      <div class="p-8 text-center text-zinc-400 text-sm">Sin archivo adjunto.</div>
    <% end %>
  </div>
</div>
