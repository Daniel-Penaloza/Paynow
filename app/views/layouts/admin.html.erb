<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= content_for?(:title) ? yield(:title) + " · PayNow Admin" : "PayNow Admin" %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-zinc-50 text-zinc-900 antialiased">
    <div class="min-h-screen flex flex-col">

      <header class="bg-zinc-900 text-white sticky top-0 z-10">
        <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-14">
          <div class="flex items-center gap-6">
            <span class="font-bold tracking-tight">PayNow <span class="text-xs text-zinc-400 font-normal ml-1">Admin</span></span>
            <nav class="hidden sm:flex items-center gap-1">
              <%= link_to "Organizaciones", admin_organizations_path,
                    class: "px-3 py-1.5 rounded-md text-sm font-medium text-zinc-300 hover:bg-zinc-800 hover:text-white transition-colors" %>
            </nav>
          </div>
          <div class="flex items-center gap-3">
            <span class="text-sm text-zinc-400 hidden sm:block"><%= Current.user.email_address %></span>
            <%= button_to "Salir", session_path, method: :delete,
                  class: "text-sm text-zinc-400 hover:text-white transition-colors cursor-pointer" %>
          </div>
        </div>
      </header>

      <% if notice.present? %>
        <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-4 w-full">
          <div class="bg-green-50 border border-green-200 text-green-800 rounded-lg px-4 py-3 text-sm">
            <%= notice %>
          </div>
        </div>
      <% end %>
      <% if alert.present? %>
        <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-4 w-full">
          <div class="bg-red-50 border border-red-200 text-red-800 rounded-lg px-4 py-3 text-sm">
            <%= alert %>
          </div>
        </div>
      <% end %>

      <main class="flex-1 max-w-6xl mx-auto px-4 sm:px-6 py-8 w-full">
        <%= yield %>
      </main>

      <footer class="border-t border-zinc-200 py-4 text-center text-xs text-zinc-400">
        PayNow Admin &copy; <%= Date.current.year %>
      </footer>
    </div>
  </body>
</html>
