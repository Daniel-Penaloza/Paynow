<%= form_with model: [:admin, organization], class: "space-y-5" do |f| %>

  <% if organization.errors.any? %>
    <div class="bg-red-950 border border-red-800 rounded-xl px-5 py-4">
      <p class="text-sm font-semibold text-red-400 mb-2">
        <%= pluralize(organization.errors.count, "error") %> al guardar:
      </p>
      <ul class="list-disc list-inside space-y-1">
        <% organization.errors.full_messages.each do |msg| %>
          <li class="text-sm text-red-400"><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Nombre %>
  <div class="flex flex-col gap-[5px]">
    <%= f.label :name, "Nombre de la organización",
        class: "text-[11px] font-bold tracking-[0.06em] uppercase text-slate-400" %>
    <%= f.text_field :name,
        placeholder: "Ej. Abarrotes García",
        class: "w-full px-[14px] py-[13px] bg-[#080c18] border border-[#1e2d45]
                rounded-xl text-slate-100 text-[15px] outline-none
                placeholder:text-[#2d3c55] transition-[border-color,box-shadow]
                focus:border-[#6366f1] focus:shadow-[0_0_0_3px_rgba(99,102,241,0.18)]" %>
  </div>

  <%# Subdominio %>
  <div class="flex flex-col gap-[5px]">
    <%= f.label :subdomain, "Subdominio",
        class: "text-[11px] font-bold tracking-[0.06em] uppercase text-slate-400" %>
    <div class="flex items-center">
      <%= f.text_field :subdomain,
          placeholder: "abarrotes-garcia",
          class: "flex-1 px-[14px] py-[13px] bg-[#080c18] border border-[#1e2d45]
                  rounded-l-xl text-slate-100 text-[15px] font-mono outline-none
                  placeholder:text-[#2d3c55] transition-[border-color,box-shadow]
                  focus:border-[#6366f1] focus:shadow-[0_0_0_3px_rgba(99,102,241,0.18)]" %>
      <span class="px-4 py-[13px] bg-[#0f172a] border border-l-0 border-[#1e2d45]
                   rounded-r-xl text-sm text-slate-500 whitespace-nowrap">
        .paynow.mx
      </span>
    </div>
    <p class="text-xs text-slate-600">Solo letras minúsculas, números y guiones.</p>
  </div>

  <%# Plan %>
  <div class="flex flex-col gap-[5px]">
    <%= f.label :plan, "Plan",
        class: "text-[11px] font-bold tracking-[0.06em] uppercase text-slate-400" %>
    <%= f.select :plan,
        [["Free", "free"], ["Básico", "basic"], ["Pro", "pro"]],
        {},
        class: "w-full px-[14px] py-[13px] bg-[#080c18] border border-[#1e2d45]
                rounded-xl text-slate-100 text-[15px] outline-none
                focus:border-[#6366f1] focus:shadow-[0_0_0_3px_rgba(99,102,241,0.18)]" %>
  </div>

  <%# Status del plan %>
  <div class="flex flex-col gap-[5px]">
    <%= f.label :plan_status, "Status",
        class: "text-[11px] font-bold tracking-[0.06em] uppercase text-slate-400" %>
    <%= f.select :plan_status,
        [["En prueba (trialing)", "trialing"], ["Activo", "active"], ["Inactivo", "inactive"]],
        {},
        class: "w-full px-[14px] py-[13px] bg-[#080c18] border border-[#1e2d45]
                rounded-xl text-slate-100 text-[15px] outline-none
                focus:border-[#6366f1] focus:shadow-[0_0_0_3px_rgba(99,102,241,0.18)]" %>
  </div>

  <%# Fechas del plan %>
  <div class="grid grid-cols-2 gap-4">
    <div class="flex flex-col gap-[5px]">
      <%= f.label :trial_ends_at, "Fin del trial",
          class: "text-[11px] font-bold tracking-[0.06em] uppercase text-slate-400" %>
      <%= f.date_field :trial_ends_at,
          class: "w-full px-[14px] py-[13px] bg-[#080c18] border border-[#1e2d45]
                  rounded-xl text-slate-100 text-[15px] outline-none
                  focus:border-[#6366f1] focus:shadow-[0_0_0_3px_rgba(99,102,241,0.18)]" %>
    </div>
    <div class="flex flex-col gap-[5px]">
      <%= f.label :current_period_ends_at, "Fin del período actual",
          class: "text-[11px] font-bold tracking-[0.06em] uppercase text-slate-400" %>
      <%= f.date_field :current_period_ends_at,
          class: "w-full px-[14px] py-[13px] bg-[#080c18] border border-[#1e2d45]
                  rounded-xl text-slate-100 text-[15px] outline-none
                  focus:border-[#6366f1] focus:shadow-[0_0_0_3px_rgba(99,102,241,0.18)]" %>
    </div>
  </div>

  <%# Acciones %>
  <div class="flex items-center gap-3 pt-2">
    <%= f.submit class: "bg-[#6366f1] hover:bg-[#818cf8] text-white text-sm font-semibold
                         px-5 py-2.5 rounded-xl transition-colors cursor-pointer border-none" %>
    <%= link_to "Cancelar", admin_organizations_path,
        class: "text-sm text-slate-500 hover:text-slate-300 transition-colors" %>
  </div>

<% end %>
