<% content_for :title, "Comprobantes · #{@business.name}" %>

<div class="space-y-6">
  <div>
    <%= link_to "← #{@business.name}", dashboard_business_path(@business), class: "text-sm text-zinc-400 hover:text-zinc-600" %>
    <h1 class="text-2xl font-bold mt-2">Comprobantes</h1>
    <p class="text-zinc-500 mt-0.5"><%= @business.name %></p>
  </div>

  <% if @receipts.any? %>
    <div class="bg-white border border-zinc-200 rounded-xl divide-y divide-zinc-100">
      <% @receipts.each do |receipt| %>
        <div class="flex items-center justify-between px-5 py-4">
          <div>
            <p class="text-sm font-medium"><%= receipt.submitted_at.strftime("%d de %B de %Y") %></p>
            <p class="text-xs text-zinc-400 mt-0.5"><%= receipt.submitted_at.strftime("%H:%M hrs") %></p>
          </div>
          <%= link_to "Ver comprobante", dashboard_business_receipt_path(@business, receipt),
                class: "text-sm text-indigo-600 hover:underline" %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-white border-2 border-dashed border-zinc-200 rounded-xl p-16 text-center">
      <p class="text-zinc-400 text-sm">No hay comprobantes aún.</p>
    </div>
  <% end %>
</div>
