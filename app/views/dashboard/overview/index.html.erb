<% content_for :title, "Inicio" %>

<div class="space-y-8">

  <%# Encabezado %>
  <div>
    <h1 class="text-2xl font-bold">Bienvenido</h1>
    <p class="text-zinc-500 mt-1">Gestiona tus negocios y comprobantes desde aquí.</p>
  </div>

  <%# Tarjetas de resumen %>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <div class="bg-white border border-zinc-200 rounded-xl p-5">
      <p class="text-sm text-zinc-500">Negocios activos</p>
      <p class="text-3xl font-bold mt-1"><%= @businesses.count %></p>
    </div>
    <div class="bg-white border border-zinc-200 rounded-xl p-5">
      <p class="text-sm text-zinc-500">Comprobantes recibidos</p>
      <p class="text-3xl font-bold mt-1"><%= Receipt.where(business: @businesses).count %></p>
    </div>
    <div class="bg-white border border-zinc-200 rounded-xl p-5">
      <p class="text-sm text-zinc-500">Hoy</p>
      <p class="text-3xl font-bold mt-1"><%= Receipt.where(business: @businesses).where(submitted_at: Date.current.all_day).count %></p>
    </div>
  </div>

  <%# Negocios %>
  <section>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold">Tus negocios</h2>
      <%= link_to "Nuevo negocio", new_dashboard_business_path,
            class: "inline-flex items-center gap-1.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors" %>
    </div>

    <% if @businesses.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @businesses.each do |business| %>
          <div class="bg-white border border-zinc-200 rounded-xl p-5 flex flex-col gap-3 hover:border-indigo-300 transition-colors">
            <div>
              <p class="font-semibold text-zinc-900"><%= business.name %></p>
              <p class="text-xs text-zinc-400 mt-0.5"><%= business.holder_name %></p>
            </div>
            <p class="text-sm font-mono text-zinc-500 bg-zinc-50 rounded px-2 py-1"><%= business.clabe %></p>
            <div class="flex items-center gap-2 mt-auto pt-1">
              <%= link_to "Ver", dashboard_business_path(business),
                    class: "flex-1 text-center text-sm font-medium text-zinc-700 border border-zinc-200 rounded-lg py-1.5 hover:bg-zinc-50 transition-colors" %>
              <%= link_to "QR", qr_dashboard_business_path(business),
                    class: "flex-1 text-center text-sm font-medium text-indigo-600 border border-indigo-200 rounded-lg py-1.5 hover:bg-indigo-50 transition-colors" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-white border-2 border-dashed border-zinc-200 rounded-xl p-12 text-center">
        <p class="text-zinc-400 text-sm">Aún no tienes negocios registrados.</p>
        <%= link_to "Crea tu primer negocio", new_dashboard_business_path,
              class: "mt-3 inline-block text-sm font-medium text-indigo-600 hover:underline" %>
      </div>
    <% end %>
  </section>

  <%# Últimos comprobantes %>
  <% if @recent_receipts.any? %>
    <section>
      <h2 class="text-lg font-semibold mb-4">Comprobantes recientes</h2>
      <div class="bg-white border border-zinc-200 rounded-xl divide-y divide-zinc-100">
        <% @recent_receipts.each do |receipt| %>
          <div class="flex items-center justify-between px-5 py-3">
            <div>
              <p class="text-sm font-medium"><%= receipt.business.name %></p>
              <p class="text-xs text-zinc-400"><%= receipt.submitted_at.strftime("%d %b %Y, %H:%M") %></p>
            </div>
            <%= link_to "Ver", dashboard_business_receipt_path(receipt.business, receipt),
                  class: "text-xs text-indigo-600 hover:underline" %>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

</div>
