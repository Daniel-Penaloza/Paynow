<% content_for :title, "Inicio" %>

<div class="space-y-8">

  <div>
    <h1 class="text-2xl font-bold tracking-tight">Bienvenido</h1>
    <p class="text-slate-500 text-sm mt-1">Gestiona tus negocios y comprobantes desde aquí.</p>
  </div>

  <%# ── Stats ──────────────────────────────────────── %>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
    <div class="bg-[#0f172a] border border-[#1e2d45] rounded-xl p-5">
      <p class="text-xs font-bold tracking-widest uppercase text-slate-500">Negocios activos</p>
      <p class="text-3xl font-extrabold tracking-tight mt-2 text-slate-100"><%= @businesses.size %></p>
    </div>
    <div class="bg-[#0f172a] border border-[#1e2d45] rounded-xl p-5">
      <p class="text-xs font-bold tracking-widest uppercase text-slate-500">Comprobantes recibidos</p>
      <p class="text-3xl font-extrabold tracking-tight mt-2 text-slate-100"><%= @total_receipts %></p>
    </div>
    <div class="bg-[#0f172a] border border-[#1e2d45] rounded-xl p-5">
      <p class="text-xs font-bold tracking-widest uppercase text-slate-500">Hoy</p>
      <p class="text-3xl font-extrabold tracking-tight mt-2 text-slate-100"><%= @today_receipts_count %></p>
    </div>
  </div>

  <%# ── Negocios ────────────────────────────────────── %>
  <section>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-base font-semibold text-slate-100">Tus negocios</h2>
      <%= link_to "Nuevo negocio", new_dashboard_business_path,
            class: "inline-flex items-center bg-[#6366f1] hover:bg-[#818cf8] text-white
                    text-sm font-semibold px-4 py-2.5 rounded-xl transition-colors" %>
    </div>

    <% if @businesses.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @businesses.each do |business| %>
          <div class="bg-[#0f172a] border border-[#1e2d45] rounded-xl p-5 flex flex-col gap-3
                      hover:border-[#6366f1] transition-colors">
            <div>
              <p class="font-semibold text-slate-100"><%= business.name %></p>
              <p class="text-xs text-slate-500 mt-0.5"><%= business.holder_name %></p>
            </div>
            <p class="text-sm font-mono text-slate-400 bg-[#080c18] border border-[#1e2d45]
                       rounded-lg px-3 py-1.5 truncate">
              <%= business.clabe %>
            </p>
            <div class="flex items-center gap-2 mt-auto pt-1">
              <%= link_to "Ver", dashboard_business_path(business),
                    class: "flex-1 text-center text-sm font-medium text-slate-400
                            border border-[#1e2d45] rounded-lg py-1.5
                            hover:border-slate-500 hover:text-slate-200 transition-colors" %>
              <%= link_to "QR", qr_dashboard_business_path(business),
                    class: "flex-1 text-center text-sm font-medium text-[#6366f1]
                            border border-[#6366f1]/30 rounded-lg py-1.5
                            hover:bg-[#6366f1]/10 transition-colors" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-[#0f172a] border-2 border-dashed border-[#1e2d45] rounded-xl p-12 text-center">
        <p class="text-slate-500 text-sm">Aún no tienes negocios registrados.</p>
        <%= link_to "Crea tu primer negocio", new_dashboard_business_path,
              class: "mt-3 inline-block text-sm font-medium text-[#6366f1] hover:text-[#818cf8]" %>
      </div>
    <% end %>
  </section>

  <%# ── Comprobantes recientes ──────────────────────── %>
  <% if @total_receipts > 0 %>
    <section>
      <div class="flex items-center justify-between mb-4 gap-4 flex-wrap">
        <h2 class="text-base font-semibold text-slate-100">Comprobantes recientes</h2>

        <%# Dropdown per_page %>
        <%= form_with url: dashboard_root_path, method: :get, data: { turbo: false } do |f| %>
          <div class="flex items-center gap-2">
            <label class="text-xs text-slate-500">Mostrar</label>
            <%= f.select :per_page,
                  options_for_select(Dashboard::OverviewController::PER_PAGE_OPTIONS.map { |n| [n, n] }, @per_page),
                  {},
                  class: "bg-[#0f172a] border border-[#1e2d45] rounded-lg px-3 py-1.5 text-sm
                          text-slate-200 focus:outline-none focus:border-[#6366f1] cursor-pointer",
                  onchange: "this.form.submit()" %>
            <label class="text-xs text-slate-500">por página</label>
          </div>
        <% end %>
      </div>

      <div class="bg-[#0f172a] border border-[#1e2d45] rounded-xl divide-y divide-[#1e2d45]">
        <% @recent_receipts.each do |receipt| %>
          <div class="flex items-center justify-between px-5 py-3 gap-4">
            <div class="flex items-center gap-3 min-w-0">
              <%= receipt_status_badge(receipt.verification_status) %>
              <div class="min-w-0">
                <p class="text-sm font-medium text-slate-100 truncate"><%= receipt.business.name %></p>
                <p class="text-xs text-slate-500 mt-0.5">
                  <%= receipt.submitted_at.strftime("%d %b %Y, %H:%M") %>
                  <% if receipt.amount_cents.present? %>
                    · <span class="text-slate-400">$<%= number_with_delimiter(receipt.amount, precision: 2, separator: ".", delimiter: ",") %></span>
                  <% end %>
                </p>
              </div>
            </div>
            <%= link_to "Ver →", dashboard_business_receipt_path(receipt.business, receipt),
                  class: "text-xs text-[#6366f1] hover:text-[#818cf8] transition-colors shrink-0" %>
          </div>
        <% end %>
      </div>

      <%# Paginador %>
      <% if @recent_receipts.total_pages > 1 %>
        <div class="flex items-center justify-between mt-4 text-sm text-slate-500">
          <span>
            <%= @recent_receipts.offset_value + 1 %>–<%= [@recent_receipts.offset_value + @per_page, @total_receipts].min %>
            de <%= @total_receipts %> comprobantes
          </span>
          <div class="flex items-center gap-1">
            <% if @recent_receipts.prev_page %>
              <%= link_to "← Anterior", dashboard_root_path(page: @recent_receipts.prev_page, per_page: @per_page),
                    class: "px-3 py-1.5 rounded-lg border border-[#1e2d45] text-slate-400
                            hover:border-slate-500 hover:text-slate-200 transition-colors" %>
            <% end %>
            <span class="px-3 py-1.5 text-slate-400">
              Página <%= @recent_receipts.current_page %> de <%= @recent_receipts.total_pages %>
            </span>
            <% if @recent_receipts.next_page %>
              <%= link_to "Siguiente →", dashboard_root_path(page: @recent_receipts.next_page, per_page: @per_page),
                    class: "px-3 py-1.5 rounded-lg border border-[#1e2d45] text-slate-400
                            hover:border-slate-500 hover:text-slate-200 transition-colors" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </section>
  <% end %>

</div>
