<% content_for :title, "Nuevo usuario — #{@organization.name}" %>

<div class="max-w-lg space-y-6">
  <div>
    <%= link_to "← #{@organization.name}", admin_organization_path(@organization),
          class: "text-sm text-slate-500 hover:text-slate-300 transition-colors" %>
    <h1 class="text-2xl font-bold tracking-tight mt-2">Nuevo usuario</h1>
    <p class="text-slate-500 text-sm mt-0.5">
      Se creará como <span class="text-slate-300 font-medium">Business Owner</span>
      de <span class="text-slate-300 font-medium"><%= @organization.name %></span>.
    </p>
  </div>

  <div class="bg-[#0f172a] border border-[#1e2d45] rounded-xl p-6">
    <%= render "form" %>
  </div>
</div>
