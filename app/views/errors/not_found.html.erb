<% content_for :title, "Página no encontrada" %>

<div class="min-h-dvh flex flex-col items-center justify-center px-6 text-center animate-up">

  <%# Logo %>
  <a href="/" class="inline-flex items-center gap-2 mb-12 opacity-60 hover:opacity-90 transition-opacity">
    <svg width="28" height="28" viewBox="0 0 38 38" fill="none">
      <rect width="38" height="38" rx="10" fill="#6366f1"/>
      <path d="M22 8l-8 13h6l-2 9 12-15h-7l3-7z" fill="white"/>
    </svg>
    <span class="text-base font-bold tracking-tight text-slate-300">PayNow</span>
  </a>

  <%# Número grande %>
  <p class="text-[120px] font-extrabold leading-none text-[#6366f1] opacity-20 select-none">
    404
  </p>

  <%# Mensaje %>
  <h1 class="mt-4 text-2xl font-bold text-slate-100">
    Esta página no existe
  </h1>
  <p class="mt-3 text-sm text-slate-400 max-w-xs">
    La dirección que ingresaste no está disponible o fue eliminada.
  </p>

  <%# CTA %>
  <a href="/"
     class="mt-8 inline-flex items-center gap-2 bg-[#6366f1] hover:bg-[#818cf8]
            text-white font-semibold text-sm rounded-xl px-6 py-3 transition-colors">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
    </svg>
    Volver al inicio
  </a>

</div>
