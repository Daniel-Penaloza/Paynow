<% content_for :title, @business.name %>

<div class="space-y-8">

  <%# ── Header ─────────────────────────────────────── %>
  <div class="flex items-start justify-between gap-4">
    <div>
      <%= link_to "← Negocios", dashboard_businesses_path,
            class: "text-sm text-slate-500 hover:text-slate-300 transition-colors" %>
      <h1 class="text-2xl font-bold tracking-tight mt-2"><%= @business.name %></h1>
      <p class="text-slate-500 text-sm mt-0.5"><%= @business.holder_name %></p>
    </div>
    <div class="flex items-center gap-2 shrink-0">
      <%= link_to "QR", qr_dashboard_business_path(@business),
            class: "text-sm font-medium text-[#6366f1] border border-[#6366f1]/30
                    rounded-xl px-4 py-2 hover:bg-[#6366f1]/10 transition-colors" %>
      <%= link_to "Editar", edit_dashboard_business_path(@business),
            class: "text-sm font-medium text-slate-400 border border-[#1e2d45]
                    rounded-xl px-4 py-2 hover:border-slate-500 hover:text-slate-200 transition-colors" %>
    </div>
  </div>

  <%# ── Info bancaria ───────────────────────────────── %>
  <div class="bg-[#0f172a] border border-[#1e2d45] rounded-xl p-6 space-y-4">
    <h2 class="text-xs font-bold tracking-widest uppercase text-slate-500">Información de pago</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <p class="text-xs text-slate-500 uppercase tracking-wide">CLABE</p>
        <p class="font-mono text-slate-100 text-sm mt-1"><%= @business.clabe %></p>
      </div>
      <div>
        <p class="text-xs text-slate-500 uppercase tracking-wide">Titular</p>
        <p class="text-slate-100 text-sm mt-1"><%= @business.holder_name %></p>
      </div>
      <% if @business.whatsapp.present? %>
        <div>
          <p class="text-xs text-slate-500 uppercase tracking-wide">WhatsApp</p>
          <p class="text-slate-100 text-sm mt-1"><%= @business.whatsapp %></p>
        </div>
      <% end %>
      <% if @business.instructions.present? %>
        <div class="sm:col-span-2">
          <p class="text-xs text-slate-500 uppercase tracking-wide">Instrucciones</p>
          <p class="text-slate-300 text-sm mt-1 leading-relaxed"><%= @business.instructions %></p>
        </div>
      <% end %>
    </div>
  </div>

  <%# ── Contabilidad ───────────────────────────────── %>
  <section>
    <h2 class="text-xs font-bold tracking-widest uppercase text-slate-500 mb-4">Ingresos verificados</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <% [
        { label: "Hoy",        amount: @totals[:today],      count: @totals[:today_count] },
        { label: "Esta semana", amount: @totals[:this_week],  count: @totals[:this_week_count] },
        { label: "Este mes",   amount: @totals[:this_month], count: @totals[:this_month_count] },
        { label: "Este año",   amount: @totals[:this_year],  count: @totals[:this_year_count] }
      ].each do |period| %>
        <div class="bg-[#0f172a] border border-[#1e2d45] rounded-xl p-4">
          <p class="text-xs text-slate-500 mb-2"><%= period[:label] %></p>
          <p class="text-lg font-bold text-slate-100 leading-none">
            $<%= number_with_delimiter(period[:amount], precision: 2, separator: ".", delimiter: ",") %>
          </p>
          <p class="text-xs text-slate-600 mt-1.5">
            <%= period[:count] %> <%= period[:count] == 1 ? "pago" : "pagos" %>
          </p>
        </div>
      <% end %>
    </div>
  </section>

  <%# ── Comprobantes recientes ──────────────────────── %>
  <%= turbo_stream_from "business_#{@business.id}_receipts" %>

  <section>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-base font-semibold text-slate-100">Comprobantes recientes</h2>
      <%= link_to "Ver todos →", dashboard_business_receipts_path(@business),
            class: "text-sm text-[#6366f1] hover:text-[#818cf8] transition-colors" %>
    </div>

    <div class="bg-[#0f172a] border border-[#1e2d45] rounded-xl divide-y divide-[#1e2d45]
                <% unless @recent_receipts.any? %>hidden<% end %>"
         id="receipts_list">
      <% @recent_receipts.each do |receipt| %>
        <%= render "dashboard/receipts/receipt", receipt: receipt, business: @business %>
      <% end %>
    </div>

    <% unless @recent_receipts.any? %>
      <div id="receipts_empty"
           class="bg-[#0f172a] border-2 border-dashed border-[#1e2d45] rounded-xl p-10 text-center">
        <p class="text-slate-500 text-sm">Aún no hay comprobantes para este negocio.</p>
        <p class="text-slate-600 text-xs mt-1">Comparte el QR para empezar a recibir pagos.</p>
      </div>
    <% end %>
  </section>

</div>
