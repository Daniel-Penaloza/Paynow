<% content_for :title, @business.name %>

<div class="space-y-8">

  <%# Encabezado %>
  <div class="flex items-start justify-between gap-4">
    <div>
      <%= link_to "← Negocios", dashboard_businesses_path, class: "text-sm text-zinc-400 hover:text-zinc-600" %>
      <h1 class="text-2xl font-bold mt-2"><%= @business.name %></h1>
      <p class="text-zinc-500 mt-0.5"><%= @business.holder_name %></p>
    </div>
    <div class="flex items-center gap-2 shrink-0">
      <%= link_to "QR", qr_dashboard_business_path(@business),
            class: "text-sm font-medium text-indigo-600 border border-indigo-200 rounded-lg px-4 py-2 hover:bg-indigo-50 transition-colors" %>
      <%= link_to "Editar", edit_dashboard_business_path(@business),
            class: "text-sm font-medium text-zinc-700 border border-zinc-200 rounded-lg px-4 py-2 hover:bg-zinc-50 transition-colors" %>
    </div>
  </div>

  <%# Info bancaria %>
  <div class="bg-white border border-zinc-200 rounded-xl p-6 space-y-4">
    <h2 class="text-sm font-semibold text-zinc-500 uppercase tracking-wide">Información de pago</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <p class="text-xs text-zinc-400">CLABE</p>
        <p class="font-mono text-zinc-900 text-sm mt-0.5"><%= @business.clabe %></p>
      </div>
      <div>
        <p class="text-xs text-zinc-400">Titular</p>
        <p class="text-zinc-900 text-sm mt-0.5"><%= @business.holder_name %></p>
      </div>
      <% if @business.whatsapp.present? %>
        <div>
          <p class="text-xs text-zinc-400">WhatsApp</p>
          <p class="text-zinc-900 text-sm mt-0.5"><%= @business.whatsapp %></p>
        </div>
      <% end %>
      <% if @business.instructions.present? %>
        <div class="sm:col-span-2">
          <p class="text-xs text-zinc-400">Instrucciones</p>
          <p class="text-zinc-900 text-sm mt-0.5"><%= @business.instructions %></p>
        </div>
      <% end %>
    </div>
  </div>

  <%# Comprobantes recientes %>
  <section>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold">Comprobantes recientes</h2>
      <%= link_to "Ver todos", dashboard_business_receipts_path(@business),
            class: "text-sm text-indigo-600 hover:underline" %>
    </div>

    <% if @recent_receipts.any? %>
      <div class="bg-white border border-zinc-200 rounded-xl divide-y divide-zinc-100">
        <% @recent_receipts.each do |receipt| %>
          <div class="flex items-center justify-between px-5 py-3">
            <p class="text-sm text-zinc-500"><%= receipt.submitted_at.strftime("%d %b %Y, %H:%M") %></p>
            <%= link_to "Ver", dashboard_business_receipt_path(@business, receipt),
                  class: "text-xs text-indigo-600 hover:underline" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-white border-2 border-dashed border-zinc-200 rounded-xl p-10 text-center">
        <p class="text-zinc-400 text-sm">Aún no hay comprobantes para este negocio.</p>
        <p class="text-zinc-400 text-xs mt-1">Comparte el QR para empezar a recibir pagos.</p>
      </div>
    <% end %>
  </section>

</div>
