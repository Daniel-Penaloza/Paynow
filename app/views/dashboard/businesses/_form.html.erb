<%= form_with model: [:dashboard, business], class: "space-y-5" do |f| %>

  <% if business.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg px-4 py-3 text-sm text-red-700">
      <ul class="list-disc list-inside space-y-1">
        <% business.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "Nombre del negocio", class: "block text-sm font-medium text-zinc-700 mb-1" %>
    <%= f.text_field :name, placeholder: "Ej. Abarrotes La Esperanza",
          class: "w-full border border-zinc-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
  </div>

  <div>
    <%= f.label :clabe, "CLABE interbancaria (18 dígitos)", class: "block text-sm font-medium text-zinc-700 mb-1" %>
    <%= f.text_field :clabe, placeholder: "000000000000000000", maxlength: 18,
          class: "w-full border border-zinc-300 rounded-lg px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
  </div>

  <div>
    <%= f.label :holder_name, "Nombre del titular", class: "block text-sm font-medium text-zinc-700 mb-1" %>
    <%= f.text_field :holder_name, placeholder: "Ej. María González López",
          class: "w-full border border-zinc-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
  </div>

  <div>
    <%= f.label :whatsapp, "WhatsApp (opcional)", class: "block text-sm font-medium text-zinc-700 mb-1" %>
    <%= f.text_field :whatsapp, placeholder: "5512345678",
          class: "w-full border border-zinc-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent" %>
    <p class="text-xs text-zinc-400 mt-1">Solo números, sin +52</p>
  </div>

  <div>
    <%= f.label :instructions, "Instrucciones adicionales (opcional)", class: "block text-sm font-medium text-zinc-700 mb-1" %>
    <%= f.text_area :instructions, rows: 3, placeholder: "Ej. Indica tu nombre en el concepto de la transferencia",
          class: "w-full border border-zinc-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent resize-none" %>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit class: "bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium px-5 py-2 rounded-lg transition-colors cursor-pointer" %>
    <%= link_to "Cancelar", dashboard_businesses_path,
          class: "text-sm text-zinc-500 hover:text-zinc-700" %>
  </div>

<% end %>
