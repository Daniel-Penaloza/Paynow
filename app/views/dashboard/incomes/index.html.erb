<% period_labels = {
  "today"      => "Hoy",
  "this_week"  => "Esta semana",
  "this_month" => "Este mes",
  "this_year"  => "Este año"
} %>
<% content_for :title, "Ingresos · #{period_labels[@period]} · #{@business.name}" %>

<div class="space-y-6">

  <%# ── Header ─────────────────────────────────────── %>
  <div class="flex items-start justify-between gap-4">
    <div>
      <%= link_to "← #{@business.name}", dashboard_business_path(@business),
            class: "text-sm text-slate-500 hover:text-slate-300 transition-colors" %>
      <h1 class="text-2xl font-bold tracking-tight mt-2">Ingresos verificados</h1>
      <p class="text-slate-500 text-sm mt-0.5"><%= @business.name %></p>
    </div>

    <%# Botón exportar Excel %>
    <% if @receipts.any? %>
      <%= link_to dashboard_business_incomes_path(@business, period: @period, format: :xlsx),
            class: "shrink-0 flex items-center gap-2 px-4 py-2 bg-[#0f172a] border border-[#1e2d45]
                    rounded-xl text-sm font-medium text-slate-300 hover:border-slate-500 hover:text-slate-100
                    transition-colors" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-emerald-400" fill="none"
             viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
        </svg>
        Exportar Excel
      <% end %>
    <% end %>
  </div>

  <%# ── Filtros de período ──────────────────────────── %>
  <div class="flex flex-wrap gap-2">
    <% period_labels.each do |period_key, label| %>
      <% active = @period == period_key %>
      <%= link_to label,
            dashboard_business_incomes_path(@business, period: period_key),
            class: [
              "px-4 py-1.5 rounded-full text-sm font-medium transition-colors",
              active ? "bg-[#6366f1] text-white"
                     : "bg-[#0f172a] border border-[#1e2d45] text-slate-400 hover:text-slate-200 hover:border-slate-500"
            ].join(" ") %>
    <% end %>
  </div>

  <%# ── Resumen ─────────────────────────────────────── %>
  <div class="flex items-center gap-6">
    <div>
      <p class="text-xs text-slate-500 uppercase tracking-wide">Total verificado</p>
      <p class="text-2xl font-bold text-slate-100 mt-1">
        $<%= number_with_delimiter(@total_amount, precision: 2, separator: ".", delimiter: ",") %>
      </p>
    </div>
    <div>
      <p class="text-xs text-slate-500 uppercase tracking-wide">Pagos</p>
      <p class="text-2xl font-bold text-slate-100 mt-1"><%= @total_count %></p>
    </div>
  </div>

  <%# ── Tabla de comprobantes ───────────────────────── %>
  <% if @receipts.any? %>
    <div class="bg-[#0f172a] border border-[#1e2d45] rounded-xl overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-[#1e2d45]">
            <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Fecha</th>
            <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Pagador</th>
            <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide hidden sm:table-cell">Banco</th>
            <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide hidden md:table-cell">Referencia</th>
            <th class="text-right px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">Monto</th>
            <th class="px-5 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-[#1e2d45]">
          <% @receipts.each do |receipt| %>
            <tr class="hover:bg-[#1e2d45]/30 transition-colors">
              <td class="px-5 py-4 text-slate-300 whitespace-nowrap">
                <% date = receipt.transfer_date || receipt.submitted_at&.to_date %>
                <%= date&.strftime("%d/%m/%Y") || "—" %>
                <% if receipt.submitted_at %>
                  <span class="block text-xs text-slate-600 mt-0.5">
                    subido <%= receipt.submitted_at.strftime("%d/%m %H:%M") %>
                  </span>
                <% end %>
              </td>
              <td class="px-5 py-4 text-slate-300">
                <% if receipt.payer_name.present? %>
                  <%= receipt.payer_name %>
                <% else %>
                  <span class="text-slate-600">—</span>
                <% end %>
              </td>
              <td class="px-5 py-4 text-slate-400 hidden sm:table-cell">
                <%= receipt.bank_name.presence || "—" %>
              </td>
              <td class="px-5 py-4 text-slate-400 font-mono text-xs hidden md:table-cell">
                <%= receipt.reference_number.presence || "—" %>
              </td>
              <td class="px-5 py-4 text-right font-semibold text-slate-100 whitespace-nowrap">
                <% if receipt.amount %>
                  $<%= number_with_delimiter(receipt.amount, precision: 2, separator: ".", delimiter: ",") %>
                <% else %>
                  <span class="text-slate-600">—</span>
                <% end %>
              </td>
              <td class="px-5 py-4 text-right">
                <%= link_to "Ver →", dashboard_business_receipt_path(@business, receipt),
                      class: "text-xs text-[#6366f1] hover:text-[#818cf8] transition-colors" %>
              </td>
            </tr>
          <% end %>
        </tbody>
        <tfoot>
          <tr class="border-t border-[#1e2d45] bg-[#0a1628]">
            <td colspan="4" class="px-5 py-3 text-xs font-semibold text-slate-400 uppercase tracking-wide">
              Total <%= period_labels[@period].downcase %> · <%= @total_count %> <%= @total_count == 1 ? "pago" : "pagos" %>
            </td>
            <td class="px-5 py-3 text-right font-bold text-slate-100">
              $<%= number_with_delimiter(@total_amount, precision: 2, separator: ".", delimiter: ",") %>
            </td>
            <td></td>
          </tr>
        </tfoot>
      </table>
    </div>
  <% else %>
    <div class="bg-[#0f172a] border-2 border-dashed border-[#1e2d45] rounded-xl p-16 text-center">
      <p class="text-slate-500 text-sm">No hay ingresos verificados para este período.</p>
    </div>
  <% end %>

</div>
