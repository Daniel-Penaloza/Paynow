<%# Shallow routing: new usa /organizations/:id/users, edit usa /users/:id %>
<%= form_with model: @user.persisted? ? [:admin, @user] : [:admin, @organization, @user],
              class: "space-y-5" do |f| %>

  <% if @user.errors.any? %>
    <div class="bg-red-950 border border-red-800 rounded-xl px-5 py-4">
      <p class="text-sm font-semibold text-red-400 mb-2">
        <%= pluralize(@user.errors.count, "error") %> al guardar el usuario:
      </p>
      <ul class="list-disc list-inside space-y-1">
        <% @user.errors.each do |error| %>
          <li class="text-sm text-red-400"><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Correo %>
  <div class="flex flex-col gap-[5px]">
    <%= f.label :email_address, "Correo electrónico",
        class: "text-[11px] font-bold tracking-[0.06em] uppercase text-slate-400" %>
    <%= f.email_field :email_address,
        required: true,
        autocomplete: "email",
        placeholder: "hola@negocio.com",
        class: "w-full px-[14px] py-[13px] bg-[#080c18] border border-[#1e2d45]
                rounded-xl text-slate-100 text-[15px] outline-none
                placeholder:text-[#2d3c55] transition-[border-color,box-shadow]
                focus:border-[#6366f1] focus:shadow-[0_0_0_3px_rgba(99,102,241,0.18)]" %>
  </div>

  <%# Contraseña %>
  <div class="flex flex-col gap-[5px]">
    <%= f.label :password,
        @user.persisted? ? "Nueva contraseña (dejar vacío para no cambiar)" : "Contraseña",
        class: "text-[11px] font-bold tracking-[0.06em] uppercase text-slate-400" %>
    <%= f.password_field :password,
        autocomplete: "new-password",
        placeholder: "••••••••",
        class: "w-full px-[14px] py-[13px] bg-[#080c18] border border-[#1e2d45]
                rounded-xl text-slate-100 text-[15px] outline-none
                placeholder:text-[#2d3c55] transition-[border-color,box-shadow]
                focus:border-[#6366f1] focus:shadow-[0_0_0_3px_rgba(99,102,241,0.18)]" %>
  </div>

  <%# Confirmar contraseña %>
  <div class="flex flex-col gap-[5px]">
    <%= f.label :password_confirmation, "Confirmar contraseña",
        class: "text-[11px] font-bold tracking-[0.06em] uppercase text-slate-400" %>
    <%= f.password_field :password_confirmation,
        autocomplete: "new-password",
        placeholder: "••••••••",
        class: "w-full px-[14px] py-[13px] bg-[#080c18] border border-[#1e2d45]
                rounded-xl text-slate-100 text-[15px] outline-none
                placeholder:text-[#2d3c55] transition-[border-color,box-shadow]
                focus:border-[#6366f1] focus:shadow-[0_0_0_3px_rgba(99,102,241,0.18)]" %>
  </div>

  <%# Acciones %>
  <div class="flex items-center gap-3 pt-2">
    <%= f.submit @user.persisted? ? "Guardar cambios" : "Crear usuario",
        class: "bg-[#6366f1] hover:bg-[#818cf8] text-white text-sm font-semibold
                px-5 py-2.5 rounded-xl transition-colors cursor-pointer border-none" %>
    <%= link_to "Cancelar", admin_organization_path(@organization),
        class: "text-sm text-slate-500 hover:text-slate-300 transition-colors" %>
  </div>

<% end %>
